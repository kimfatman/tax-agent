<view class="page">
  <view class="profile-header">
    <view class="avatar">
      <text class="avatar-text">{{userInfo.name ? userInfo.name[0] : 'U'}}</text>
    </view>
    <view class="profile-info">
      <text class="profile-name">{{userInfo.name || '未登录'}}</text>
      <text class="profile-phone">{{userInfo.phone || ''}}</text>
      <text wx:if="{{userInfo.city}}" class="profile-city">{{userInfo.city}}</text>
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-value">{{userInfo.orderCount || 0}}</text>
      <text class="stat-label">成交订单</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{userInfo.rating || 0}}</text>
      <text class="stat-label">评分</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{roleMap[userInfo.role] || '用户'}}</text>
      <text class="stat-label">角色</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bind:tap="goToCompany">
      <text class="menu-icon">🏢</text>
      <text class="menu-label">公司管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bind:tap="goToMyOrders">
      <text class="menu-icon">📋</text>
      <text class="menu-label">我的订单</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item">
      <text class="menu-icon">🌓</text>
      <text class="menu-label">深色模式</text>
      <switch checked="{{isDark}}" bindchange="toggleTheme" />
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item logout" bind:tap="handleLogout">
      <text class="menu-label">退出登录</text>
    </view>
  </view>
</view>
