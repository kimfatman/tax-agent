<view class="page">
  <view class="search-bar">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <input placeholder="搜索订单标题..." value="{{search}}" bindinput="onSearchInput" bindconfirm="handleSearch" />
    </view>
  </view>

  <view class="filters">
    <view class="filter-row">
      <picker mode="selector" range="{{industries}}" bindchange="onIndustryChange">
        <view class="filter-tag {{currentIndustry ? 'active' : ''}}">
          {{currentIndustry || '全部行业'}}
        </view>
      </picker>
      <picker mode="selector" range="{{cities}}" bindchange="onCityChange">
        <view class="filter-tag {{currentCity ? 'active' : ''}}">
          {{currentCity || '全部城市'}}
        </view>
      </picker>
      <picker mode="selector" range="{{priceRanges}}" bindchange="onPriceChange">
        <view class="filter-tag {{currentPrice ? 'active' : ''}}">
          {{currentPrice || '金额范围'}}
        </view>
      </picker>
    </view>
  </view>

  <view class="order-list">
    <view wx:if="{{orders.length === 0 && !loading}}" class="empty-state">
      <text>暂无匹配的订单</text>
    </view>

    <view wx:for="{{orders}}" wx:key="_id" class="order-card" bind:tap="goToDetail" data-id="{{item._id}}">
      <view class="order-header">
        <text class="order-title">{{item.title}}</text>
        <text class="order-price">¥{{item.price}}</text>
      </view>
      <view class="order-tags">
        <text class="tag">{{item.industry}}</text>
        <text wx:if="{{item.city}}" class="tag">{{item.city}}</text>
        <text class="status-tag status-{{item.status}}">{{statusMap[item.status]}}</text>
      </view>
      <view class="order-footer">
        <text class="publisher">{{item.publisherName || '未知'}}</text>
        <text class="time">{{formatTime(item.createdAt)}}</text>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading-more">
      <text>加载中...</text>
    </view>
  </view>
</view>
