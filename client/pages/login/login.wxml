<view class="page">
  <view class="header">
    <text class="logo">财税甩单</text>
    <text class="subtitle">财税行业高效协作平台</text>
  </view>

  <view class="form-card">
    <view class="tabs">
      <view class="tab {{activeTab === 'login' ? 'active' : ''}}" bind:tap="switchTab" data-tab="login">登录</view>
      <view class="tab {{activeTab === 'register' ? 'active' : ''}}" bind:tap="switchTab" data-tab="register">注册</view>
    </view>

    <view wx:if="{{activeTab === 'login'}}" class="form">
      <view class="input-group">
        <label>手机号</label>
        <input class="input" type="text" placeholder="请输入手机号" maxlength="11" value="{{phone}}" bindinput="onPhoneInput" />
      </view>
      <view class="input-group">
        <label>密码</label>
        <input class="input" type="password" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
      </view>
      <button class="btn btn-primary btn-block" loading="{{loading}}" bind:tap="handleLogin">登 录</button>
    </view>

    <view wx:if="{{activeTab === 'register'}}" class="form">
      <view class="input-group">
        <label>姓名</label>
        <input class="input" type="text" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
      </view>
      <view class="input-group">
        <label>手机号</label>
        <input class="input" type="text" placeholder="请输入手机号" maxlength="11" value="{{phone}}" bindinput="onPhoneInput" />
      </view>
      <view class="input-group">
        <label>密码</label>
        <input class="input" type="password" placeholder="请输入密码（至少6位）" value="{{password}}" bindinput="onPasswordInput" />
      </view>
      <view class="input-group">
        <label>所在城市</label>
        <input class="input" type="text" placeholder="请输入城市" value="{{city}}" bindinput="onCityInput" />
      </view>
      <view class="input-group">
        <label>业务类型（用逗号分隔）</label>
        <input class="input" type="text" placeholder="如: 代理记账,税务筹划" value="{{businessTypes}}" bindinput="onBusinessTypesInput" />
      </view>
      <button class="btn btn-primary btn-block" loading="{{loading}}" bind:tap="handleRegister">注 册</button>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">注册即表示同意《服务协议》和《隐私政策》</text>
  </view>
</view>
